{
  // Typecheck for CF Pages Functions (thread 0026). CF builds functions/ with esbuild, which does NOT
  // resolve identifiers — a missing import ships silently and throws ReferenceError at runtime (the
  // generate-contract 1101 incident). `npm run build` runs this project so that class of bug fails the
  // build instead of taking down a prod endpoint. strict is required for discriminated-union narrowing
  // (the `if (!x.ok) return x.res` pattern used across all endpoints).
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler"
  },
  "include": ["functions"]
}
